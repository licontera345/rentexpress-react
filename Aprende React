import React, { useState } from 'react';
import { useProducts } from '../hooks/useProducts';
import ProductForm from './ProductForm';  // Precisa dun formulario de produto para engadir/edita que se programa abaixo

function ProductCRUD() {
  const { products, loading, removeProduct, editProduct, addProduct } = useProducts();
  const [editingProduct, setEditingProduct] = useState(null);
  const [isAdding, setIsAdding] = useState(false);

  // Manejador para guardar (Crea o Edita)
  const handleSave = async (data) => {
    if (editingProduct) {
      await editProduct(editingProduct.id, data);
    } else {
      await addProduct(data);
    }
    setEditingProduct(null);
    setIsAdding(false);
  };

  if (loading) return <p>Cargando...</p>;

  return (
    <div>
      <h2>Gestión de Productos</h2>
      
      {/* Botón para mostrar formulario de creación */}
      {!isAdding && !editingProduct && (
        <button onClick={() => setIsAdding(true)}>+ Nuevo Producto</button>
      )}

      {/* Mostrar formulario si estamos creando o editando */}
      {(isAdding || editingProduct) && (
        <ProductForm 
          initialData={editingProduct} 
          onSubmit={handleSave} 
          onCancel={() => { setEditingProduct(null); setIsAdding(false); }} 
        />
      )}

      <table>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {products.map(p => (
            <tr key={p.id}>
              <td>{p.name}</td>
              <td>${p.price}</td>
              <td>
                <button onClick={() => setEditingProduct(p)}>Editar</button>
                <button onClick={() => removeProduct(p.id)}>Borrar</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}
Para CRUD necesitamos un formulario de produto para editar/crear. Este será un compoñente react ProductForm que garda estado interno para modo creación ou modo edición components/ProductForm.jsx
import React, { useState, useEffect } from 'react';

const ProductForm = ({ initialData, onSubmit, onCancel }) => {
  const [product, setProduct] = useState({ name: '', price: '' });

  // Si recibimos datos iniciales (Edición), rellenamos el formulario
  useEffect(() => {
    if (initialData) {
      setProduct(initialData);
    }
  }, [initialData]);

  const handleChange = (e) => {
    const { name, value } = e.target;
    setProduct(prev => ({ ...prev, [name]: value }));
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    onSubmit(product); // Enviamos el objeto al padre
  };

  return (
    <form onSubmit={handleSubmit} >
      <h3>{initialData ? 'Editar Producto' : 'Nuevo Producto'}</h3>
      <input 
        name="name" 
        value={product.name} 
        onChange={handleChange} 
        placeholder="Nombre" 
        required 
      />
      <input 
        name="price" 
        type="number" 
        value={product.price} 
        onChange={handleChange} 
        placeholder="Precio" 
        required 
      />
      <button type="submit">Guardar</button>
      <button type="button" onClick={onCancel}>Cancelar</button>
    </form>
  );
};

export default ProductForm;

