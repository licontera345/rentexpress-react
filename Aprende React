PokemonList: con Outlet actúa como un PlaceHolder. Dille a React Router o sitio preciso donde engadir os compoñentes fillos cando se usan rutas aniñadas.routes.
import { useEffect, useState } from "react";
import PokemonCard from "./PokemonCard"
import "./PokemonList.css"
import GetForm from "./GetForm";
import { Outlet } from "react-router-dom"; // Import Outlet


function PokemonList() {
    const [pokemons, setPokemons] = useState([]);
    useEffect(() => {
        getPokemons(1, 10);
    }, [])
    const fetchPokemon = async (index) => {
        const response = await
            fetch(`https://pokeapi.co/api/v2/pokemon/${index}`)
        const data = await response.json();
        return data;
    }
    const getPokemons = async (from, to) => {
        const pkmnArr = [];
        for (let i = from; i <= to; i++) {
            const pokemon = await fetchPokemon(i);
            pkmnArr.push(pokemon);
        }
        setPokemons(pkmnArr);
    }
    const pokemonCards = pokemons.map((pokemon) => {
        return (<PokemonCard key={pokemon.id}
            pokemon={pokemon}>
        </PokemonCard>
        );
    })

    return (
        <div>
            <Outlet />
            <GetForm getPokemons={getPokemons}></GetForm>
            <ul className="pokemon-list">
                {pokemonCards}
            </ul>
        </div>
    )
}
export default PokemonList
