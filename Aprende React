•	Custom hooks
hooks/useProducts.js: Aquí é onde reside a lóxica de negocio e a xestión do estado local . Cando se borra un produto no servidor, tamen debemos actualizar o estado de React para que desapareza da pantalla sen recargar.
import { useState, useEffect } from 'react';
import { fetchProducts, deleteProduct, updateProduct } from '../services/productService'; // importo os servizos

export const useProducts = () => {
  const [products, setProducts] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  useEffect(() => {
    const getProducts = async () => {
      try {
        const data = await fetchProducts();
        setProducts(data);
      } catch (err) {
        setError("Failed to load products");
      } finally {
        setLoading(false);
      }
    };

    getProducts();
  }, []);

const removeProduct = async (id) => {
    try {
      await deleteProduct(id);
      // Actualizamos el estado local filtrando el producto borrado
      // En React,   "prev" (abreviatura de previous state) representa o valor máis recente do estado
      // xunto antes de que se aplique a actualización.  
      // Pasamos a setProducts unha función de actualización en lugar dun valor directo
      // prev: É o array de productos tal como está no estado agora mesmo.
      // .map(...): Crea un novo array (React necesita un obxecto novo para detectar o cambio).
      // p.id === id ? updated : p: Se o ID coincide co que acabas de editar, sustitue  o vello polo novo (updated).
      // Se non coincide, deixa o producto tal como estaba (p).
      setProducts(prev => prev.map(p => p.id === id ? updated : p));
    } catch (err) {
      alert("No se pudo borrar el producto");
    }
  };

const editProduct = async (id, newData) => {
    try {
      const updated = await updateProduct(id, newData);
      // Actualizamos el producto específico en el estado
      setProducts(prev => prev.map(p => p.id === id ? updated : p));
    } catch (err) {
      alert("Error al actualizar");
    }
  };

  return { products, loading, error, removeProduct, editProduct };
};
