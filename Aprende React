GetForm: formulario que escoita cambios nos campos de entrada de números do rango e cando se envía, manda o rango ao compoñente pai (a través de chamada ao método getPokemons(from, to))
import { useState } from "react";

function GetForm(props) {
    const [from, setFrom] = useState(1);
    const [to, setTo] = useState(10);

    const handleFromInput = (e) => {
        setFrom(e.target.value);
    }
    const handleToInput = (e) => {
        setTo(e.target.value);
    }
    const handleSubmit = (e) => {
        e.preventDefault();
        props.getPokemons(from, to);
    }
    return (
        <form onSubmit={handleSubmit}>
            <fieldset>
                <label htmlFor="from-pokemon">From:</label>
                <input type="number"
                    id="from-pokemon"
                    min={1}
                    onChange={handleFromInput} />
            </fieldset>
            <fieldset>
                <label htmlFor="to-pokemon">To:</label>
                <input type="number"
                    id="to-pokemon"
                    onChange={handleToInput} />
            </fieldset>
            <button>Get Pokemons!</button>
        </form>
    )
}
export default GetForm
